# Copy this to ".env" and adjust as needed:  cp .env.example .env

# --- OBS WebSocket (OBS runs on your host) ---------------------------------
# Enable in OBS:  Tools -> WebSocket Server Settings -> Enable WebSocket server.
# Leave OBS_HOST as-is for rootless podman; it resolves to your host machine.
OBS_HOST=host.containers.internal
OBS_PORT=4455
# Set this to the password shown in OBS WebSocket settings (blank = no auth).
OBS_PASSWORD=

# --- Whisper STT (external OpenAI-compatible server) -----------------------
# Base URL MUST include the /v1 suffix. The app posts audio to
# {STT_BASE_URL}/audio/transcriptions.
STT_BASE_URL=http://linux-al-ml-beast.singhs:11435/v1
# Model id as listed by the server's /v1/models. base = fast; large-v3 = best.
STT_MODEL=Systran/faster-whisper-base
# Only needed if your server requires an API key; leave blank otherwise.
STT_API_KEY=

# --- Ollama (local LLM for meeting minutes, runs on your HOST) -------------
# The app reaches your host's Ollama via host.containers.internal. Only change
# OLLAMA_URL if Ollama runs elsewhere (e.g. http://192.168.1.50:11434).
OLLAMA_URL=http://host.containers.internal:11434
# A model that exists in `ollama list`, e.g. gemma4:12b, qwen2.5:14b, llama3.2.
OLLAMA_MODEL=llama3.2

# --- TLS / HTTPS (optional) ------------------------------------------------
# By default the app serves plain HTTP. To avoid Chrome/Brave auto-upgrading
# http://localhost to https, run ./gen-cert.sh (prefers mkcert for a trusted,
# warning-free cert) — it writes ./certs and the app then serves HTTPS on the
# same port automatically. You normally don't need to set these; only override
# if your cert/key live at non-default paths inside the container.
SSL_CERTFILE=
SSL_KEYFILE=
