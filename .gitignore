# --- Secrets / local config ---
# .env holds OBS_PASSWORD, STT_API_KEY, etc. Keep .env.example tracked.
.env
.env.local

# --- TLS certificates (generated by ./gen-cert.sh) ---
certs/*.pem
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- App data / SQLite (normally lives in ~/MeetingMinutes, but ignore any
#     stray copies created during local runs) ---
*.db
*.sqlite
*.sqlite3
data/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
